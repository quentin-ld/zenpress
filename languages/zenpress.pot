msgid "Security"
msgstr ""

#: inc/meta/clean-admin-bar.meta.php:13
msgid "Clean up the WordPress Admin Bar"
msgstr ""

#: inc/meta/clean-admin-bar.meta.php:14
msgid "Removes redundant or unnecessary items from the WordPress Admin Bar, both in the backend and frontend. This streamlines the admin experience and improves usability."
msgstr ""

#: inc/meta/clean-admin-bar.meta.php:18
#: inc/meta/clean-dashboard-items.meta.php:18
#: inc/meta/disable-login-language-selector.meta.php:15
msgid "User interface"
msgstr ""

#: inc/meta/clean-dashboard-items.meta.php:13
msgid "Remove redundant items from the WordPress Dashboard"
msgstr ""

#: inc/meta/clean-dashboard-items.meta.php:14
msgid "Removes various default and plugin-related widgets from the WordPress dashboard, including the Quick Draft widget, Incoming Links, and the Welcome Panel. This helps declutter the Dashboard, improving both performance and usability. The Dashboard should display important information about your website, not plugin advertising."
msgstr ""

#: inc/meta/disable-adjacent-posts.meta.php:13
msgid "Disable adjacent posts link tags in the header"
msgstr ""

#: inc/meta/disable-adjacent-posts.meta.php:14
msgid "Removes the rel=\"prev\" and rel=\"next\" link tags from the wp_head output, which can improve performance by reducing unnecessary HTML in the header."
msgstr ""

#: inc/meta/disable-adjacent-posts.meta.php:18
#: inc/meta/disable-dashicons.meta.php:18
#: inc/meta/disable-dns-prefetch.meta.php:18
#: inc/meta/disable-emoji-scripts.meta.php:18
#: inc/meta/disable-jquery-migrate.meta.php:18
#: inc/meta/disable-oembed.meta.php:15
#: inc/meta/disable-pdf-thumbnails.meta.php:15
#: inc/meta/disable-rss.meta.php:15
#: inc/meta/disable-shortlink.meta.php:15
#: inc/meta/disable-wlw-manifest.meta.php:15
#: inc/meta/disable-xmlrpc-rsdlink.meta.php:15
#: inc/meta/remove-gutenberg-unwanted-block-patterns.meta.php:15
#: inc/meta/remove-rest-api-link.meta.php:15
#: inc/meta/separate-gutenberg-core-block-styles.meta.php:15
msgid "Performance"
msgstr ""

#: inc/meta/disable-author-archives.meta.php:13
msgid "Disable author archives and redirect to 404"
msgstr ""

#: inc/meta/disable-author-archives.meta.php:14
msgid "Disable author archive pages by redirecting them to a 404 page. This helps improve security by preventing attackers from gathering information about authors and their posts."
msgstr ""

#: inc/meta/disable-dashicons.meta.php:13
msgid "Disable Dashicons for non-logged-in users"
msgstr ""

#: inc/meta/disable-dashicons.meta.php:14
msgid "Prevents WordPress from loading the Dashicons CSS for visitors who are not logged in, which can improve frontend performance."
msgstr ""

#: inc/meta/disable-dns-prefetch.meta.php:13
msgid "Disable DNS prefetch"
msgstr ""

#: inc/meta/disable-dns-prefetch.meta.php:14
msgid "Removes DNS prefetch resource hints from the wp_head, which can reduce unnecessary DNS lookups for some websites."
msgstr ""

#: inc/meta/disable-emoji-scripts.meta.php:13
msgid "Disable WordPress emoji scripts and styles"
msgstr ""

#: inc/meta/disable-emoji-scripts.meta.php:14
msgid "Removes all emoji-related scripts, styles, and filters from both frontend and admin areas to improve performance."
msgstr ""

#: inc/meta/disable-jquery-migrate.meta.php:13
msgid "Disable jQuery Migrate on the frontend"
msgstr ""

#: inc/meta/disable-jquery-migrate.meta.php:14
msgid "Removes jQuery Migrate script from loading on the frontend of the website to improve performance while keeping it enabled in the admin area."
msgstr ""

#: inc/meta/disable-login-language-selector.meta.php:13
msgid "Disable the Login Language Selector"
msgstr ""

#: inc/meta/disable-login-language-selector.meta.php:14
msgid "Disables the language selector on the WordPress login page."
msgstr ""

#: inc/meta/disable-oembed.meta.php:13
msgid "Disable oEmbed"
msgstr ""

#: inc/meta/disable-oembed.meta.php:14
msgid "Removes all features related to oEmbed, including auto-discovery, embedding of external content, and the wp-embed script, to improve site performance by eliminating unnecessary API calls and scripts."
msgstr ""

#: inc/meta/disable-pdf-thumbnails.meta.php:13
msgid "Disable PDF thumbnails"
msgstr ""

#: inc/meta/disable-pdf-thumbnails.meta.php:14
msgid "Disable the generation of PDF thumbnails by filtering out the fallback image sizes, which helps improve performance by avoiding the creation of unnecessary image files for PDFs."
msgstr ""

#: inc/meta/disable-pingback-trackback.meta.php:13
msgid "Disable pingback and trackback"
msgstr ""

#: inc/meta/disable-pingback-trackback.meta.php:14
msgid "Removes the X-Pingback header, disables pingbacks and trackbacks on new posts, and prevents self-pingbacks. This improves security and performance by reducing unnecessary requests and mitigating spam or DDoS risks."
msgstr ""

#: inc/meta/disable-rss.meta.php:13
msgid "Disable all WordPress feeds"
msgstr ""

#: inc/meta/disable-rss.meta.php:14
msgid "Disables all WordPress feeds (RDF, RSS, RSS2, Atom, and comment feeds), removes feed links from <head>, and redirects any feed request to the homepage."
msgstr ""

#: inc/meta/disable-shortlink.meta.php:13
msgid "Disable WordPress shortlink generation"
msgstr ""

#: inc/meta/disable-shortlink.meta.php:14
msgid "Removes shortlink functionality by disabling the header and template redirect actions, preventing WordPress from outputting shortlink tags and headers."
msgstr ""

#: inc/meta/disable-wlw-manifest.meta.php:13
msgid "Disable the Windows Live Writer (WLW) manifest link"
msgstr ""

#: inc/meta/disable-wlw-manifest.meta.php:14
msgid "Removes the WLW manifest link from the <head> section of WordPress pages, reducing unnecessary metadata output."
msgstr ""

#: inc/meta/disable-woocommerce-cart-fragments.meta.php:13
msgid "Disable WooCommerce cart fragments script"
msgstr ""

#: inc/meta/disable-woocommerce-cart-fragments.meta.php:14
msgid "Removes the WooCommerce cart fragments JavaScript responsible for dynamically updating cart contents, improving performance when live cart updates are unnecessary."
msgstr ""

#: inc/meta/disable-woocommerce-cart-fragments.meta.php:15
#: inc/meta/disable-woocommerce-scripts-styles.meta.php:15
#: inc/meta/disable-woocommerce-stripe-scripts.meta.php:15
#: inc/meta/disable-woocommerce-widgets.meta.php:15
#: inc/meta/hide-woocommerce-version.meta.php:15
#: inc/meta/remove-woocommerce-patterns.meta.php:15
msgid "WooCommerce"
msgstr ""

#: inc/meta/disable-woocommerce-scripts-styles.meta.php:13
msgid "Disable WooCommerce scripts and styles on non-WooCommerce pages"
msgstr ""

#: inc/meta/disable-woocommerce-scripts-styles.meta.php:14
msgid "Dequeues WooCommerce scripts and styles on non-WooCommerce pages such as the homepage, blog posts, and custom pages, improving performance by reducing unnecessary asset loading."
msgstr ""

#: inc/meta/disable-woocommerce-stripe-scripts.meta.php:13
msgid "Disable unnecessary Stripe scripts on WooCommerce pages"
msgstr ""

#: inc/meta/disable-woocommerce-stripe-scripts.meta.php:14
msgid "Prevents loading of Stripe-related scripts on WooCommerce product and cart pages when Payment Request Button Support (PRBS) is disabled, improving site performance."
msgstr ""

#: inc/meta/disable-woocommerce-widgets.meta.php:13
msgid "Disable WooCommerce widgets"
msgstr ""

#: inc/meta/disable-woocommerce-widgets.meta.php:14
msgid "Unregisters default WooCommerce widgets such as cart, product filters, and product listings, improving performance by reducing unnecessary widget loading."
msgstr ""

#: inc/meta/disable-xmlrpc-rsdlink.meta.php:13
msgid "Disable XML-RPC and remove the RSD link"
msgstr ""

#: inc/meta/disable-xmlrpc-rsdlink.meta.php:14
msgid "Disables XML-RPC functionality to reduce attack surface (brute force, DDoS) and removes the RSD link from the HTML head for better security and reduced exposure."
msgstr ""

#: inc/meta/hide-woocommerce-version.meta.php:13
msgid "Hide WooCommerce version from HTTP headers, scripts, and styles"
msgstr ""

#: inc/meta/hide-woocommerce-version.meta.php:14
msgid "Removes the WooCommerce version number from HTTP headers and from script/style URLs, improving security by preventing version disclosure."
msgstr ""

#: inc/meta/hide-wordpress-version.meta.php:13
msgid "Hide WordPress version from HTTP headers, scripts, and styles"
msgstr ""

#: inc/meta/hide-wordpress-version.meta.php:14
msgid "Removes the WordPress version number from the HTML head, the generator tag, and script/style URLs, improving security by preventing version disclosure."
msgstr ""

#: inc/meta/protect-wp-login.meta.php:13
msgid "Protect the wp-login form from brute force attacks"
msgstr ""

#: inc/meta/protect-wp-login.meta.php:14
msgid "Adds brute force protection to the WordPress login form by hiding detailed error messages, limiting failed login attempts per IP, and temporarily blocking further attempts after repeated failures."
msgstr ""

#: inc/meta/remove-gutenberg-unwanted-block-patterns.meta.php:13
msgid "Disable unwanted default block patterns in Gutenberg editor"
msgstr ""

#: inc/meta/remove-gutenberg-unwanted-block-patterns.meta.php:14
msgid "Disables the loading of remote block patterns and removes the default core block patterns in WordPress, improving performance by preventing unnecessary block patterns from being loaded."
msgstr ""

#: inc/meta/remove-rest-api-link.meta.php:13
msgid "Remove REST API links from the <head>"
msgstr ""

#: inc/meta/remove-rest-api-link.meta.php:14
msgid "Removes REST API discovery links from the <head> section of the site, improving performance and reducing unnecessary HTML output while keeping the REST API available."
msgstr ""

#: inc/meta/remove-woocommerce-patterns.meta.php:13
msgid "Remove WooCommerce patterns"
msgstr ""

#: inc/meta/remove-woocommerce-patterns.meta.php:14
msgid "Removes all WooCommerce remote block patterns to prevent unnecessary editor patterns from being registered."
msgstr ""

#: inc/meta/separate-gutenberg-core-block-styles.meta.php:13
msgid "Enable separate loading of core block styles"
msgstr ""

#: inc/meta/separate-gutenberg-core-block-styles.meta.php:14
msgid "Forces WordPress to load core block styles separately, improving performance by only loading the styles required for the blocks used on a page."
msgstr ""

