#: inc/meta/block-user-enumeration.meta.php:13
msgid "Block user enumeration"
msgstr ""

#: inc/meta/block-user-enumeration.meta.php:14
msgid "Prevents attackers from enumerating users via query-string and permalink-style author URLs."
msgstr ""

#: inc/meta/block-user-enumeration.meta.php:18
#: inc/meta/disable-author-archives.meta.php:18
#: inc/meta/disable-pingback-trackback.meta.php:15
